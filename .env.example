# ============================================================
#  ShopNow — Variables de entorno
#  Copia este archivo como .env y llena tus valores reales
#  NUNCA subas el archivo .env a GitHub
# ============================================================

# Base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=shopnow_db

# JWT — Cambia esto por una cadena larga y aleatoria
JWT_SECRET=cambia_este_secreto_por_uno_muy_seguro_2026

# PIN de acceso al panel de administrador
ADMIN_PIN=TU_PIN_ADMIN

# Puerto del servidor (default: 3000)
PORT=3000

# Correo electrónico para envío de notificaciones (opcional)
# Usa una App Password de Gmail, no tu contraseña normal
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Origen permitido para CORS
ALLOWED_ORIGIN=http://localhost:3000

# Entorno
NODE_ENV=development
